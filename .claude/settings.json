{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-check.sh\"",
            "if": "Bash(git commit*)",
            "timeout": 180,
            "statusMessage": "Running pnpm lint && pnpm build before commit..."
          }
        ]
      }
    ]
  }
}
