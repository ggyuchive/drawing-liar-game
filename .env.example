VITE_YORKIE_API_ADDR=https://api.yorkie.dev
VITE_YORKIE_API_KEY=

# Keyword-secrecy backend (Vercel Functions). Required in production;
# locally, `pnpm dev` falls back to an insecure in-document assignment,
# while `vercel dev` with these set exercises the real server path.
# Signs the per-tab session tokens (any long random string).
JWT_SECRET=
# Upstash Redis. Vercel's Upstash integration injects these KV_* names
# automatically; a standalone Upstash setup uses UPSTASH_REDIS_REST_URL /
# UPSTASH_REDIS_REST_TOKEN instead (the server accepts either pair).
KV_REST_API_URL=
KV_REST_API_TOKEN=
